# ============================================================================
# OpenSwarm Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your API keys.
#
# MINIMUM SETUP: Only OpenRouter key is needed for chat/reasoning.
# FULL SETUP: Add optional keys for media generation features.
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED — OpenRouter (primary provider for all LLM calls)
# ----------------------------------------------------------------------------
# Get your key at: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=openrouter/anthropic/claude-sonnet-4

# Note: OPENAI_API_KEY is set to your OpenRouter key because Agency Swarm
# uses the OpenAI Python SDK internally. OPENAI_BASE_URL redirects all
# calls to OpenRouter instead of api.openai.com.

# ----------------------------------------------------------------------------
# OPTIONAL — Google Gemini (Veo video generation, Gemini image generation)
# ----------------------------------------------------------------------------
# Get your key at: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-google-api-key

# Models that require GOOGLE_API_KEY:
#   - veo-3.1-generate-preview (video)
#   - veo-3.1-fast-generate-preview (video)
#   - gemini-2.5-flash-image (image)
#   - gemini-3-pro-image-preview (image)

# ----------------------------------------------------------------------------
# OPTIONAL — fal.ai (Seedance video, background removal)
# ----------------------------------------------------------------------------
# Get your key at: https://fal.ai/dashboard/keys
# FAL_KEY=your-fal-key

# Models that require FAL_KEY:
#   - seedance-1.5-pro (video)
#   - background removal / Pixelcut (image)

# ----------------------------------------------------------------------------
# OPTIONAL — OpenAI Direct (Sora video, gpt-image-1.5)
# ----------------------------------------------------------------------------
# Only needed if you want Sora video or gpt-image-1.5 specifically.
# These models ONLY work with a direct OpenAI key, NOT through OpenRouter.
# OPENAI_DIRECT_KEY=sk-your-direct-openai-key

# ----------------------------------------------------------------------------
# OPTIONAL — Search & Integrations
# ----------------------------------------------------------------------------
# SEARCH_API_KEY=your-search-api-key     # Web search for deep research agent
# COMPOSIO_API_KEY=your-composio-key     # Gmail, Slack, GitHub integrations
# COMPOSIO_USER_ID=your-composio-user    # Required with Composio
# PEXELS_API_KEY=your-pexels-key         # Stock photos for slides agent
